# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============================================================
# DEMO MODE — Integrations shown as "Connected" for the demo.
# To use REAL keys later, replace "demo" with your actual key
# or JSON, and the "Demo" badge will disappear automatically.
# ============================================================

# Google Search Console — set to your service-account JSON for live rankings
NEXT_PUBLIC_GSC_CONNECTED=demo
GSC_SERVICE_ACCOUNT_JSON=

# SEMrush API — set to your API key for live ranking/backlink data
NEXT_PUBLIC_SEMRUSH_CONNECTED=demo
SEMRUSH_API_KEY=

# Resend (email) — set to your API key for real report delivery
NEXT_PUBLIC_RESEND_CONNECTED=demo
RESEND_API_KEY=

# Session secret (HMAC-signed cookies)
SESSION_SECRET=seoscout-dev-secret-change-in-production
